#!/usr/bin/env python3
"""
Hamtar NFL/NCAA-nyheter server-side (inga CORS-restriktioner har, till skillnad
fran webblasaren) och skriver dem till news.json, som sidan sedan bara laser
som en vanlig statisk fil. Ersatter den tidigare klientsidan-losningen med
allorigins/codetabs/corsproxy.io - dessa gratisproxyer visade sig opalitliga
(nere/blockerade) och orsakade att nyhetsfliken antingen fastnade i evig
laddning eller foll tillbaka pa statiska exempelartiklar. Kors av
.github/workflows/news.yml var 20:e minut.
"""
import json
import re
import sys
import urllib.request
from datetime import datetime, timezone
from email.utils import parsedate_to_datetime

ESPN_NEWS_ENDPOINTS = {
    'nfl': 'https://site.api.espn.com/apis/site/v2/sports/football/nfl/news?limit=50',
    'ncaa': 'https://site.api.espn.com/apis/site/v2/sports/football/college-football/news?limit=50',
}
FOX_PARTNER_KEY = 'MB0Wehpmuj2lUhuRhQaafhBjAJqaPU244mlTDK1i'
FOX_RSS_ENDPOINTS = {
    'nfl': f'https://api.foxsports.com/v2/content/optimized-rss?partnerKey={FOX_PARTNER_KEY}&size=30&tags=fs/nfl',
    'ncaa': f'https://api.foxsports.com/v2/content/optimized-rss?partnerKey={FOX_PARTNER_KEY}&size=30&tags=fs/cfb',
}
LEGACY_RSS = {
    'nfl': [
        ('ESPN NFL', 'https://www.espn.com/espn/rss/nfl/news'),
        ('Yahoo NFL', 'https://sports.yahoo.com/nfl/rss/'),
    ],
    'ncaa': [
        ('ESPN College Football', 'https://www.espn.com/espn/rss/ncf/news'),
        ('CollegeFootballTalk', 'https://collegefootballtalk.nbcsports.com/feed/'),
    ],
    'insider': [
        ('ProFootballTalk', 'https://profootballtalk.nbcsports.com/feed/'),
        ('Bleacher Report Rykten', 'https://bleacherreport.com/articles/feed/nfl'),
    ],
}
ALL_NAMED_INSIDERS = ['Adam Schefter', 'Ian Rapoport', 'Tom Pelissero', 'Mike Garafolo', 'Judy Battista']
INSIDER_SIGNAL_KEYWORDS = ['trade', 'rumor', 'signing', 'signs', 'agrees to terms', 'contract', 'sources',
                           'source:', 'reportedly', 'update', 'deal', 'holds out', 'free agency',
                           'negotiation', 'insider', 'suspended', 'released', 'waived']

HEADERS = {'User-Agent': 'Mozilla/5.0 (compatible; NFL-briefen-fetcher/1.0; '
                         '+https://timsor68.github.io/NFL-briefen/)'}


def now_iso():
    return datetime.now(timezone.utc).isoformat()


def http_get(url, timeout=15):
    req = urllib.request.Request(url, headers=HEADERS)
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return resp.read()


def parse_rfc822(date_str):
    try:
        dt = parsedate_to_datetime(date_str)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return dt.astimezone(timezone.utc).isoformat()
    except Exception:
        return now_iso()


def strip_html(text):
    return re.sub('<[^<]+?>', '', text or '').strip()


def fetch_espn_news(sport_key, source_label):
    try:
        import xml.etree.ElementTree  # noqa (import kept local-scope clean)
        raw = http_get(ESPN_NEWS_ENDPOINTS[sport_key])
        data = json.loads(raw)
        out = []
        for a in data.get('articles', []):
            title = a.get('headline') or ''
            if not title:
                continue
            byline = a.get('byline')
            out.append({
                'title': title,
                'link': (a.get('links') or {}).get('web', {}).get('href', '#'),
                'description': a.get('description') or '',
                'pubDate': a.get('published') or a.get('lastModified') or now_iso(),
                'source': f"{source_label} · {byline}" if byline else source_label,
                'thumbnail': ((a.get('images') or [{}])[0]).get('url', ''),
            })
        return out
    except Exception as e:
        print(f"ESPN news error ({sport_key}): {e}", file=sys.stderr)
        return []


def fetch_fox_rss(sport_key):
    import xml.etree.ElementTree as ET
    wanted_category = 'college-football' if sport_key == 'ncaa' else 'nfl'
    ns = {'media': 'http://search.yahoo.com/mrss/'}
    try:
        raw = http_get(FOX_RSS_ENDPOINTS[sport_key])
        root = ET.fromstring(raw)
        out = []
        for item in root.findall('.//item'):
            category = (item.findtext('category') or '').strip().lower()
            if category != wanted_category:
                continue
            title = (item.findtext('title') or '').strip()
            if not title:
                continue
            link = (item.findtext('link') or '#').strip()
            description = (item.findtext('description') or '').strip()
            pub_date_text = item.findtext('pubDate') or ''
            media = item.find('media:content', ns)
            if media is None:
                media = item.find('media:thumbnail', ns)
            thumbnail = media.get('url') if media is not None else ''
            out.append({
                'title': title,
                'link': link,
                'description': description,
                'pubDate': parse_rfc822(pub_date_text) if pub_date_text else now_iso(),
                'source': 'FOX Sports',
                'thumbnail': thumbnail,
            })
        return out
    except Exception as e:
        print(f"FOX RSS error ({sport_key}): {e}", file=sys.stderr)
        return []


def fetch_legacy_rss(feeds):
    import xml.etree.ElementTree as ET
    out = []
    for name, url in feeds:
        try:
            raw = http_get(url)
            root = ET.fromstring(raw)
            for item in root.findall('.//item'):
                title = (item.findtext('title') or '').strip()
                if not title:
                    continue
                link = (item.findtext('link') or '#').strip()
                desc = strip_html(item.findtext('description') or '')[:180]
                pub_date_text = item.findtext('pubDate') or ''
                out.append({
                    'title': title,
                    'link': link,
                    'description': (desc + '...') if desc else '',
                    'pubDate': parse_rfc822(pub_date_text) if pub_date_text else now_iso(),
                    'source': name,
                    'thumbnail': '',
                })
        except Exception as e:
            print(f"Legacy RSS error ({name}): {e}", file=sys.stderr)
    return out


def dedupe(articles):
    seen = set()
    out = []
    for a in articles:
        key = (a.get('title') or '').strip().lower()
        if not key or key in seen:
            continue
        seen.add(key)
        out.append(a)
    return out


def sort_desc(articles):
    def keyfn(a):
        try:
            return datetime.fromisoformat(a['pubDate'].replace('Z', '+00:00'))
        except Exception:
            return datetime.min.replace(tzinfo=timezone.utc)
    return sorted(articles, key=keyfn, reverse=True)


def build():
    espn_nfl = fetch_espn_news('nfl', 'ESPN NFL')
    fox_nfl = fetch_fox_rss('nfl')
    espn_ncaa = fetch_espn_news('ncaa', 'ESPN College Football')
    fox_ncaa = fetch_fox_rss('ncaa')

    legacy_nfl = fetch_legacy_rss(LEGACY_RSS['nfl'])
    legacy_ncaa = fetch_legacy_rss(LEGACY_RSS['ncaa'])
    legacy_insider = fetch_legacy_rss(LEGACY_RSS['insider'])

    nfl_articles = sort_desc(dedupe(espn_nfl + fox_nfl + legacy_nfl))
    ncaa_articles = sort_desc(dedupe(espn_ncaa + fox_ncaa + legacy_ncaa))

    general_pool = espn_nfl + fox_nfl
    named_lower = [n.lower() for n in ALL_NAMED_INSIDERS]
    step1 = [a for a in general_pool if any(n in (a.get('source') or '').lower() for n in named_lower)]

    def has_signal(a):
        t = (a.get('title') or '').lower()
        d = (a.get('description') or '').lower()
        return any(k in t or k in d for k in INSIDER_SIGNAL_KEYWORDS)

    step2 = [a for a in general_pool if has_signal(a)]
    insider_articles = sort_desc(dedupe(step1 + step2 + legacy_insider))

    return {
        'generatedAt': now_iso(),
        'nfl': nfl_articles[:50],
        'ncaa': ncaa_articles[:50],
        'insider': insider_articles[:50],
    }


if __name__ == '__main__':
    result = build()
    with open('news.json', 'w', encoding='utf-8') as f:
        json.dump(result, f, ensure_ascii=False, indent=2)
    print(f"Wrote news.json: nfl={len(result['nfl'])} ncaa={len(result['ncaa'])} "
          f"insider={len(result['insider'])}")

